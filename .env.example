# ============================================
# NextBench iOS — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file.

# --- EAS / Expo ---
EXPO_PUBLIC_EAS_PROJECT_ID=
EXPO_PUBLIC_APP_ENV=development

# --- Firebase Web SDK Config ---
# Not strictly needed for native builds (native SDK reads from GoogleService-Info.plist),
# but useful if you ever use the JS SDK as a fallback.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_FIRESTORE_DB=(default)

# --- Google Sign-In ---
# Web Client ID from Firebase Console > Auth > Google provider > Web SDK config
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# --- Cloudinary (optional — image hosting) ---
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
